# Environment Variables - Copy this to .env and fill in values

# Deployment Environment
ENVIRONMENT=production
DEBUG=False

# Database - Use Supabase PostgreSQL URL
DATABASE_URL=postgresql://postgres:PASSWORD@db.XXXXXXX.supabase.co:5432/postgres?sslmode=require

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Configuration
API_VERSION=v1
API_TITLE=AI Carbon Footprint Coach
API_DESCRIPTION=REST API for tracking and reducing carbon footprint

# Ollama (Local LLM) - Will be set up separately
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=gemma:2b
OLLAMA_TIMEOUT=120

# SMTP Configuration (Optional - for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Carbon Coach

# CORS Origins
CORS_ORIGINS=["https://carbon-coach.vercel.app", "http://localhost:5173", "http://localhost:3000"]

# Database Configuration
DB_ECHO=False

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
